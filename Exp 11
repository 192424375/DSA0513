import pandas as pd
import matplotlib.pyplot as plt

# Read dataset (must contain Date and Volume columns)
df = pd.read_csv('alphabet_stock_data.csv')

# Convert Date column to datetime
df['Date'] = pd.to_datetime(df['Date'])

# Set Date as index
df.set_index('Date', inplace=True)

# Filter between two dates
filtered = df.loc['2023-01-01':'2023-03-31']

# Plot bar chart
filtered['Volume'].plot(kind='bar', figsize=(10, 5), color='blue')

plt.title('Trading Volume of Alphabet Inc.')
plt.xlabel('Date')
plt.ylabel('Volume')
plt.tight_layout()
plt.show()
