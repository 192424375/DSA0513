import pandas as pd
import matplotlib.pyplot as plt

# Load dataset (example CSV with Date, Open, High, Low, Close, Volume)
df = pd.read_csv('alphabet_stock_data.csv', parse_dates=['Date'])

# Set Date as index
df.set_index('Date', inplace=True)

# Filter between two dates
start_date = '2023-01-01'
end_date = '2023-06-30'
filtered_df = df.loc[start_date:end_date]

# Plot bar chart for Volume
plt.figure(figsize=(10, 5))
filtered_df['Volume'].plot(kind='bar', color='skyblue')

plt.title('Alphabet Inc. Trading Volume')
plt.xlabel('Date')
plt.ylabel('Volume')
plt.tight_layout()
plt.show()
