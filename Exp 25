import matplotlib.pyplot as plt

x = [1, 2, 3, 4]

y1 = [10, 20, 30, 40]
y2 = [40, 30, 20, 10]

plt.plot(x, y1, label='Series 1', color='blue', marker='o')
plt.plot(x, y2, label='Series 2', color='red', linestyle='--')

plt.xlabel('X Axis')
plt.ylabel('Values')
plt.title('Multiple Line Plot')

plt.legend()
plt.grid()
plt.show()
