import pandas as pd
import numpy as np

# Create random DataFrame
np.random.seed(0)
df = pd.DataFrame(np.random.randn(10, 4), columns=list('ABCD'))

# Function to color values
def color_values(val):
    if val < 0:
        return 'color: red'
    else:
        return 'color: black'

# Apply style
styled_df = df.style.applymap(color_values)

# Display (works in Jupyter Notebook)
styled_df
