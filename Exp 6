import pandas as pd
import matplotlib.pyplot as plt

# Load dataset
df = pd.read_csv('alphabet_stock_data.csv', parse_dates=['Date'])
df.set_index('Date', inplace=True)

# Filter dates
filtered_df = df.loc['2023-01-01':'2023-06-30']

# Scatter plot (Volume vs Close price)
plt.figure(figsize=(8, 5))
plt.scatter(filtered_df['Volume'], filtered_df['Close'], color='green')

plt.title('Volume vs Closing Price (Alphabet Inc.)')
plt.xlabel('Volume')
plt.ylabel('Closing Price')
plt.grid(True)
plt.show()
