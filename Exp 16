import pandas as pd
import numpy as np

# Create random DataFrame
np.random.seed(0)
df = pd.DataFrame(np.random.randn(10, 4), columns=['A', 'B', 'C', 'D'])

# Function to apply colors
def color_values(val):
    if val < 0:
        return 'color: red'
    else:
        return 'color: black'

# Apply styling
styled_df = df.style.map(color_values)

# Display (works in Jupyter Notebook)
styled_df
