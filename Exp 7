import pandas as pd

# Example sales_data DataFrame
data = {
    'Item': ['Item1', 'Item2', 'Item1', 'Item2', 'Item3'],
    'Sale_amt': [200, 150, 300, 400, 250]
}

df = pd.DataFrame(data)

# Pivot table
pivot_table = pd.pivot_table(
    df,
    values='Sale_amt',
    index='Item',
    aggfunc=['max', 'min']
)

print(pivot_table)
