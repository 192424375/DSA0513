import pandas as pd
import numpy as np

# Create DataFrame
np.random.seed(0)
df = pd.DataFrame(np.random.randn(10, 4), columns=list('ABCD'))

# Convert some values to NaN
df.iloc[0, 0] = np.nan
df.iloc[3, 2] = np.nan
df.iloc[5, 1] = np.nan

# Highlight NaN values
styled_df = df.style.highlight_null(color='red')

styled_df
